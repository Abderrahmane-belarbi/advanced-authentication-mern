# App
PORT=5000
NODE_ENV=development
MODE=development

# Database/Auth
MONGODB_URI=mongodb://127.0.0.1:27017/crewauth
JWT_SECRET=replace_with_a_strong_secret

# Frontend URLs
CLIENT_URL=http://localhost:3000
LOCAL_CLIENT_URL=http://localhost:3000
PUBLIC_CLIENT_URL=https://your-frontend-domain.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
LOCAL_GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
PUBLIC_GOOGLE_REDIRECT_URI=https://your-backend-domain.com/api/auth/google/callback

# Gmail API sender
REFRESH_TOKEN=your_google_refresh_token
EMAIL_FROM=your_email@gmail.com

# Optional
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
VITE_API_REQUEST_TIMEOUT_MS=15000